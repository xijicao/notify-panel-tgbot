ADMIN_PASSWORD=change_this_password
AUTH_ENABLED=false
SECRET_KEY=generate_a_random_secret
TG_BOT_TOKEN=replace_with_your_bot_token
TG_CHAT_ID=replace_with_your_chat_id
HOST=127.0.0.1
